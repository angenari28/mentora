{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/mentora-web/browser",
  "framework": "angular",
  "redirects": [
    {
      "source": "/",
      "has": [{"type": "header", "key": "accept-language", "value": "^en"}],
      "destination": "/en/",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/pt/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/en/(.*)",
      "destination": "/en/index.html"
    },
    {
      "source": "/pt/(.*)",
      "destination": "/pt/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/pt/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
